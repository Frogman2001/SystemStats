<Window x:Class="SystemStats.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="System Stats Client"
        Height="480"
        Width="820"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <TextBlock x:Name="TimeTextBlock"
                   Grid.Row="0"
                   Margin="0,0,0,12"
                   FontSize="18"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Text="System stats will appear here." />

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12">
            <Button x:Name="RefreshButton"
                    Width="110"
                    Margin="0,0,8,0"
                    Padding="10,5"
                    Content="Refresh Stats"
                    Click="RefreshButton_Click" />
            <Button x:Name="QuitButton"
                    Width="80"
                    Padding="10,5"
                    Content="Quit"
                    Click="QuitButton_Click" />
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left column: CPU + Memory -->
            <StackPanel Grid.Column="0"
                        Margin="0,0,8,0">
                <GroupBox Header="CPU"
                          Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Overall:"
                                       Width="70"
                                       VerticalAlignment="Center" />
                            <ProgressBar x:Name="CpuAverageProgressBar"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="16"
                                         Width="220"
                                         Margin="4,0,0,0" />
                            <TextBlock x:Name="CpuAverageTextBlock"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="Per core:"
                                   Margin="0,8,0,4"
                                   FontWeight="Bold" />

                        <ScrollViewer Height="140"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="CpuPerCoreItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,2">
                                            <TextBlock Text="{Binding Name}"
                                                       Width="70"
                                                       VerticalAlignment="Center" />
                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding Value, Mode=OneWay}"
                                                         Height="12"
                                                         Width="200"
                                                         Margin="4,0,0,0" />
                                            <TextBlock Text="{Binding Value, StringFormat='{}{0:F0}%'}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Memory">
                    <StackPanel Margin="8">
                        <TextBlock x:Name="MemorySummaryTextBlock"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- Right column: Temps + Other -->
            <StackPanel Grid.Column="1"
                        Margin="8,0,0,0">
                <GroupBox Header="Temperatures (°C)"
                          Margin="0,0,0,8">
                    <ScrollViewer Height="160"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TempsTextBlock"
                                   Margin="8"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </GroupBox>

                <GroupBox Header="Fans / Other">
                    <StackPanel Margin="8">
                        <TextBlock x:Name="FansTextBlock"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap" />
                        <Separator Margin="0,4,0,4" />
                        <TextBlock x:Name="OtherStatsTextBlock"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>
    </Grid>
</Window>